@RestController
public class CommentsController {
  
  private static final int MAX_COMMENT_LENGTH = 500;
  private static final int MIN_USERNAME_LENGTH = 1;
  private static final int MAX_USERNAME_LENGTH = 50;
  private static final Pattern USERNAME_PATTERN = 
    Pattern.compile("^[a-zA-Z0-9_-]+$");
  
  @PostMapping("/comments")
  public Comment createComment(
      @RequestHeader(value="x-auth-token") String token, 
      @RequestBody CommentRequest input) throws BadRequest {
    
    // Validate username
    if (input.username == null || input.username.isEmpty()) {
      throw new BadRequest("Username cannot be empty");
    }
    if (input.username.length() > MAX_USERNAME_LENGTH) {
      throw new BadRequest("Username too long");
    }
    if (!USERNAME_PATTERN.matcher(input.username).matches()) {
      throw new BadRequest("Invalid username characters");
    }
    
    // Validate comment body
    if (input.body == null || input.body.isEmpty()) {
      throw new BadRequest("Comment cannot be empty");
    }
    if (input.body.length() > MAX_COMMENT_LENGTH) {
      throw new BadRequest("Comment too long");
    }
    
    // Additional security: check for injection attempts
    if (containsSuspiciousPatterns(input.body)) {
      throw new BadRequest("Comment contains suspicious patterns");
    }
    
    return Comment.create(input.username, input.body);
  }
  
  private boolean containsSuspiciousPatterns(String input) {
    // Check for SQL injection keywords
    String lowerInput = input.toLowerCase();
    return lowerInput.contains("union ")
        || lowerInput.contains("select ")
        || lowerInput.contains("drop ")
        || lowerInput.contains("delete ");
  }
}

